# ──────────────────────────────────────────────────────────────────────
# Klareg Live — template for the Portainer stack `.env`.
# Copy to `.env` at the repo root (same dir as docker-compose.yml) and
# fill the CHANGE_ME fields. Do NOT commit the filled file.
# ──────────────────────────────────────────────────────────────────────

# ─── Laravel core ───
APP_NAME=KlaregLive
APP_ENV=production
# Generate once: docker run --rm klareg-live:latest php -r "echo 'base64:'.base64_encode(random_bytes(32));"
APP_KEY=CHANGE_ME
APP_DEBUG=false
APP_URL=https://overlay.philippedelaval.dev
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# ─── Hostnames (must match DNS + Traefik labels) ───
APP_HOST=overlay.philippedelaval.dev
REVERB_HOST=reverb.philippedelaval.dev
TRAEFIK_NETWORK=traefik
TRAEFIK_CERTRESOLVER=cloudflare

# ─── Database (Postgres) ───
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=klareg
DB_USERNAME=klareg
DB_PASSWORD=CHANGE_ME

# ─── Laravel drivers ───
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
LOG_CHANNEL=stack
LOG_LEVEL=info

# ─── Reverb (WebSocket) ───
# APP_KEY/SECRET can be any random string — don't reuse your Twitch or APP_KEY.
REVERB_APP_ID=klareg-overlay
REVERB_APP_KEY=CHANGE_ME_random_string
REVERB_APP_SECRET=CHANGE_ME_random_string
REVERB_PORT=443
REVERB_SCHEME=https

# ─── Twitch ───
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CHANNEL_NAME=Klareg
TWITCH_CHANNEL_ID=118497645
TWITCH_REDIRECT_URI=https://overlay.philippedelaval.dev/twitch/oauth/callback

# ─── CORS ───
CORS_ALLOWED_ORIGINS=https://overlay.philippedelaval.dev
